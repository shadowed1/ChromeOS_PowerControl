#!/bin/bash
RED=$(tput setaf 1)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
BLUE=$(tput setaf 4)
MAGENTA=$(tput setaf 5)
CYAN=$(tput setaf 6)
BOLD=$(tput bold)
RESET=$(tput sgr0)

INSTALL_DIR_FILE="/usr/local/bin/.ChromeOS_PowerControl.install_dir"
if [ -f "$INSTALL_DIR_FILE" ]; then
    INSTALL_DIR=$(cat "$INSTALL_DIR_FILE")
else
    INSTALL_DIR="/usr/local/bin/ChromeOS_PowerControl"
fi
INSTALL_DIR="${INSTALL_DIR%/}"

CONFIG_FILE="$INSTALL_DIR/config.sh"
PID_FILE="$INSTALL_DIR/.sleepcontrol_pid"
RUN_FLAG="$INSTALL_DIR/.sleepcontrol_enabled"
LOG_FILE="/var/log/sleepcontrol.log"
BATTERY_STATUS_PATH="/sys/class/power_supply/BAT0/status"

DEFAULT_BATTERY_DELAY=14
DEFAULT_POWER_DELAY=30

BATTERY_DELAY=
POWER_DELAY=

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi

    BATTERY_DELAY="${BATTERY_DELAY:-$DEFAULT_BATTERY_DELAY}"
    POWER_DELAY="${POWER_DELAY:-$DEFAULT_POWER_DELAY}"
}

save_config() {
    {
        echo "BATTERY_DELAY=$BATTERY_DELAY"
        echo "POWER_DELAY=$POWER_DELAY"
    } > "$CONFIG_FILE"
}

simulate_activity_loop() {
    local delay_minutes=$1
    local end=$((SECONDS + delay_minutes * 60))
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Starting simulate_activity_loop for $delay_minutes minutes." | tee -a "$LOG_FILE"
    while [ $SECONDS -lt $end ]; do
        dbus-send --system --type=method_call \
            --dest=org.chromium.PowerManager \
            /org/chromium/PowerManager \
            org.chromium.PowerManager.HandleUserActivity \
            int32:0 int32:0
        sleep 120
    done
    echo "$(date '+%Y-%m-%d %H:%M:%S') - simulate_activity_loop ended." | tee -a "$LOG_FILE"
}

monitor_idle_activity() {
    touch "$RUN_FLAG"
    echo $$ > "$PID_FILE"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - sleepcontrol started (PID $$)." | tee -a "$LOG_FILE"

    local last_reload_time=0
    local delay_minutes
    local active=1
    local sim_pid=

    tail -Fn0 /var/log/power_manager/powerd.LATEST | while read -r line; do

        # Exit if run flag removed (stop command)
        if [ ! -f "$RUN_FLAG" ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - sleepcontrol stopped, exiting loop." | tee -a "$LOG_FILE"
            [ -n "$sim_pid" ] && kill "$sim_pid" 2>/dev/null
            rm -f "$PID_FILE"
            exit 0
        fi

        # Reload config every 120 seconds
        now=$(date +%s)
        if (( now - last_reload_time >= 120 )); then
            load_config
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Config reloaded: BATTERY_DELAY=$BATTERY_DELAY, POWER_DELAY=$POWER_DELAY" | tee -a "$LOG_FILE"
            last_reload_time=$now
        fi

        if [ -f "$BATTERY_STATUS_PATH" ]; then
            status=$(cat "$BATTERY_STATUS_PATH")
            if [ "$status" = "Discharging" ]; then
                delay_minutes=$BATTERY_DELAY
            else
                delay_minutes=$POWER_DELAY
            fi
        else
            delay_minutes=$DEFAULT_POWER_DELAY
        fi

        if echo "$line" | grep -q "User activity stopped"; then
            if [ "$active" -eq 1 ]; then
                active=0
                simulate_activity_loop "$delay_minutes" &
                sim_pid=$!
                echo "$(date '+%Y-%m-%d %H:%M:%S') - User inactive, started simulate_activity_loop (PID $sim_pid)." | tee -a "$LOG_FILE"
            fi

        elif echo "$line" | grep -q "User activity reported"; then
            if [ "$active" -eq 0 ]; then
                active=1
                if [ -n "$sim_pid" ]; then
                    kill "$sim_pid" 2>/dev/null
                    echo "$(date '+%Y-%m-%d %H:%M:%S') - User active, killed simulate_activity_loop (PID $sim_pid)." | tee -a "$LOG_FILE"
                    sim_pid=
                fi
            fi
        fi
    done
}

stop_monitoring() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            kill "$PID" && echo "$(date '+%Y-%m-%d %H:%M:%S') - sleepcontrol stopped (PID $PID)." | tee -a "$LOG_FILE"
        fi
        rm -f "$PID_FILE"
    else
        echo "sleepcontrol is not running."
    fi
    rm -f "$RUN_FLAG"
}

case "$1" in
    start)
        if [ -f "$LOG_FILE" ] && [ "$(stat -c%s "$LOG_FILE")" -gt 32768 ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Truncated log file (exceeded 32KB)." | tee -a "$LOG_FILE"
            > "$LOG_FILE"
        fi

        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "sleepcontrol is already running."
            exit 1
        fi

        nohup "$0" __monitor__ >> "$LOG_FILE" 2>&1 &
        echo $! > "$PID_FILE"
        touch "$RUN_FLAG"
        echo "sleepcontrol started."
        ;;
    stop)
        stop_monitoring
        ;;
    battery)
        if [ -n "$2" ]; then
            if [[ "$2" =~ ^[0-9]+$ ]]; then
                BATTERY_DELAY=$2
                save_config
                echo "Battery delay set to $BATTERY_DELAY minutes."
            else
                echo "Invalid delay value. Please enter a positive integer."
                exit 1
            fi
        else
            load_config
            echo "Battery delay: $BATTERY_DELAY minutes"
        fi
        ;;
    power)
        if [ -n "$2" ]; then
            if [[ "$2" =~ ^[0-9]+$ ]]; then
                POWER_DELAY=$2
                save_config
                echo "Power delay set to $POWER_DELAY minutes."
            else
                echo "Invalid delay value. Please enter a positive integer."
                exit 1
            fi
        else
            load_config
            echo "Power delay: $POWER_DELAY minutes"
        fi
        ;;
    status|"")
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            load_config
            echo "${GREEN}SleepControl is running.${RESET}"
            echo "Sleep delayed: Battery=$BATTERY_DELAY, Power=$POWER_DELAY"
        else
            load_config
            echo "${YELLOW}sleepcontrol is not running.${RESET}"
            echo "Sleep delayed: Battery=$BATTERY_DELAY, Power=$POWER_DELAY"
        fi
        ;;
    __monitor__)
        monitor_idle_activity
        ;;
    *)
        echo "Usage: sleepcontrol [start | stop | battery [minutes] | power [minutes] | status]"
        exit 1
        ;;
esac

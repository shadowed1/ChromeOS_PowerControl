#!/bin/bash
RED=$(tput setaf 1)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
BLUE=$(tput setaf 4)
MAGENTA=$(tput setaf 5)
CYAN=$(tput setaf 6)
BOLD=$(tput bold)
RESET=$(tput sgr0)

INSTALL_DIR_FILE="/usr/local/bin/.ChromeOS_PowerControl.install_dir"
if [ -f "$INSTALL_DIR_FILE" ]; then
    INSTALL_DIR=$(cat "$INSTALL_DIR_FILE")
else
    INSTALL_DIR="/usr/local/bin/ChromeOS_PowerControl"
fi
INSTALL_DIR="${INSTALL_DIR%/}"

CONFIG_FILE="$INSTALL_DIR/config.sh"
PID_FILE="$INSTALL_DIR/.sleepcontrol_pid"
RUN_FLAG="$INSTALL_DIR/.sleepcontrol_enabled"
LOG_FILE="/var/log/sleepcontrol.log"
BATTERY_STATUS_PATH="/sys/class/power_supply/BAT0/status"
SIM_FILE="/tmp/sleepcontrol.sim"
SIM_FILE_TMP="/tmp/sleepcontrol.sim.tmp"

DEFAULT_BATTERY_DELAY=14
DEFAULT_POWER_DELAY=30
DEFAULT_BATTERY_BACKLIGHT=4
DEFAULT_POWER_BACKLIGHT=10

BATTERY_DELAY=
POWER_DELAY=
BATTERY_BACKLIGHT=
POWER_BACKLIGHT=
audio_active=0

BATTERY_DELAY=$DEFAULT_BATTERY_DELAY
POWER_DELAY=$DEFAULT_POWER_DELAY
BATTERY_BACKLIGHT=$DEFAULT_BATTERY_BACKLIGHT
POWER_BACKLIGHT=$DEFAULT_POWER_BACKLIGHT

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
    validate_config
}

validate_config() {
    if [[ -z "$BATTERY_DELAY" || ! "$BATTERY_DELAY" =~ ^[0-9]+$ ]]; then
        BATTERY_DELAY=$DEFAULT_BATTERY_DELAY
    fi
    if [[ -z "$POWER_DELAY" || ! "$POWER_DELAY" =~ ^[0-9]+$ ]]; then
        POWER_DELAY=$DEFAULT_POWER_DELAY
    fi
    if [[ -z "$BATTERY_BACKLIGHT" || ! "$BATTERY_BACKLIGHT" =~ ^[0-9]+$ ]]; then
        BATTERY_BACKLIGHT=$DEFAULT_BATTERY_BACKLIGHT
    fi
    if [[ -z "$POWER_BACKLIGHT" || ! "$POWER_BACKLIGHT" =~ ^[0-9]+$ ]]; then
        POWER_BACKLIGHT=$DEFAULT_POWER_BACKLIGHT
    fi
}

save_config() {
    validate_config
    sed -i "s/^BATTERY_DELAY=.*/BATTERY_DELAY=$BATTERY_DELAY/" "$CONFIG_FILE" || echo "BATTERY_DELAY=$BATTERY_DELAY" >> "$CONFIG_FILE"
    sed -i "s/^POWER_DELAY=.*/POWER_DELAY=$POWER_DELAY/" "$CONFIG_FILE" || echo "POWER_DELAY=$POWER_DELAY" >> "$CONFIG_FILE"
    sed -i "s/^BATTERY_BACKLIGHT=.*/BATTERY_BACKLIGHT=$BATTERY_BACKLIGHT/" "$CONFIG_FILE" || echo "BATTERY_BACKLIGHT=$BATTERY_BACKLIGHT" >> "$CONFIG_FILE"
    sed -i "s/^POWER_BACKLIGHT=.*/POWER_BACKLIGHT=$POWER_BACKLIGHT/" "$CONFIG_FILE" || echo "POWER_BACKLIGHT=$POWER_BACKLIGHT" >> "$CONFIG_FILE"
}

load_config

save_sim_time() {
    date +%s%3N >> "$SIM_FILE"
    tail -n 10 "$SIM_FILE" > "$SIM_FILE.tmp" && mv "$SIM_FILE.tmp" "$SIM_FILE"
}


send_fake_activity() {
    dbus-send --system --type=method_call \
        --dest=org.chromium.PowerManager \
        /org/chromium/PowerManager \
        org.chromium.PowerManager.HandleUserActivity int32:0 int32:0
    save_sim_time
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Simulated user activity." >> "$LOG_FILE"
}

monitor_idle_activity() {
    echo $$ > "$PID_FILE"
    touch "$RUN_FLAG"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - SleepControl started (PID $$)." > "$LOG_FILE"
    local active=1
    local backlight_off=0
    local kb_brightness_restored=1
    local saved_kb_brightness=$(sudo ectool pwmgetkblight | awk '{print $NF}')
    local power_backlight_ts=$(date +%s)
    local battery_backlight_ts=$(date +%s)

    tail -Fn0 /var/log/power_manager/powerd.LATEST | while read -r line; do
        now_ms=$(date +%s%3N)
        if (( now_ms % 60 == 0 )); then
            load_config
        fi
        case "$line" in
            *"User activity stopped"*)
                active=0
                kb_brightness_restored=0
                echo "$(date '+%Y-%m-%d %H:%M:%S') - User went idle." >> "$LOG_FILE"
                ;;

            *"User activity reported"*|*"User activity ongoing"*|*"Audio activity"*|*"Enabling wakeup for"*|*"Chrome is using normal display mode"*)
                timestamp=$(echo "$line" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]+Z')
                if [[ -n "$timestamp" ]]; then
                    reported_epoch_ms=$(date -d "${timestamp}" +%s%3N)
                else
                    reported_epoch_ms=$(date +%s%3N)
                fi

                
                               matched_recent_sim=0
                if [ -f "$SIM_FILE" ]; then
                    while read -r sim_ts; do
                        [[ "$sim_ts" =~ ^[0-9]+$ ]] || continue
                        diff=$(( reported_epoch_ms - sim_ts ))
                        if (( diff >= 0 && diff <= 500 )); then  # match if within 0.5 seconds
                            matched_recent_sim=1
                            break
                        fi
                    done < "$SIM_FILE"
                fi
                
                if [ "$matched_recent_sim" -eq 0 ]; then
                    if [ "$active" -eq 0 ]; then
                        active=1
                        echo "$(date '+%Y-%m-%d %H:%M:%S') - Real user activity resumed." >> "$LOG_FILE"
                    fi
                    if [ "$backlight_off" -eq 1 ]; then
                        sudo ectool backlight 1
                        backlight_off=0
                        saved_kb_brightness=$(sudo ectool pwmgetkblight | awk '{print $NF}')
                    fi

                    if [ "$kb_brightness_restored" -eq 0 ] && [ "$saved_kb_brightness" -ge 0 ]; then
                        sudo ectool pwmsetkblight "$saved_kb_brightness"
                        kb_brightness_restored=1
                        sudo ectool backlight 1
                        active=1
                        echo "$(date '+%Y-%m-%d %H:%M:%S') - Restored keyboard brightness to $saved_kb_brightness%" >> "$LOG_FILE"
                    fi
                    if [ "$status" = "Discharging" ]; then
                        battery_backlight_ts=$now_ms
                    else
                        power_backlight_ts=$now_ms
                    fi
                fi
                ;;
        esac

            status=$(cat "$BATTERY_STATUS_PATH" 2>/dev/null)

        if [[ "$status" == "Discharging" ]]; then
            backlight_delay=$((BATTERY_BACKLIGHT * 60))
            last_ts=$battery_backlight_ts
            suspend_delay=$((BATTERY_DELAY * 60))
        else
            backlight_delay=$((POWER_BACKLIGHT * 60))
            last_ts=$power_backlight_ts
            suspend_delay=$((POWER_DELAY * 60))
        fi

        
        
        
echo "$(date '+%Y-%m-%d %H:%M:%S') - Idle detected, checking backlight timers. now_ms=$now_ms last_ts=$last_ts backlight_delay=$backlight_delay" >> "$LOG_FILE"

        if (( now_ms - last_ts >= backlight_delay )); then
            if [ "$backlight_off" -eq 0 ]; then
                sudo ectool backlight 0
                backlight_off=1
                echo "$(date '+%Y-%m-%d %H:%M:%S') - Turned off backlight due to inactivity." >> "$LOG_FILE"
            fi
        fi

            kb_current=$(sudo ectool pwmgetkblight | awk '{print $NF}')
        if (( kb_current > 0 )); then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Skipped suspend: keyboard backlight still active ($kb_current%)." >> "$LOG_FILE"
            continue
        fi

        if (( now_ms - last_ts >= suspend_delay )); then
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Suspending system due to inactivity." >> "$LOG_FILE"
    dbus-send --system --type=method_call \
        --dest=org.chromium.PowerManager \
        /org/chromium/PowerManager \
        org.chromium.PowerManager.RequestSuspend

    # Add cooldown after suspend to prevent repeat suspend attempts
    sleep 60

    # Reset timers to avoid immediately retriggering suspend
    power_backlight_ts=$now_ms
    battery_backlight_ts=$now_ms
    backlight_off=0
    saved_kb_brightness=$(sudo ectool pwmgetkblight | awk '{print $NF}')
    kb_brightness_restored=1
    active=1
    sudo ectool backlight 1

    continue  # Skip rest of loop this cycle
fi


        if (( now_ms % 60 == 0 )); then
            send_fake_activity
        fi
    done
}

stop_monitoring() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p "$PID" > /dev/null 2>&1; then
            # Kill the entire process group
            echo "Stopping SleepControl (PGID: $PID)..."
            kill -- -"$PID" 2>/dev/null  # note the minus sign before PID for PGID
            sleep 1
            # Also kill the main PID explicitly
            kill "$PID" 2>/dev/null
            echo "Stopped SleepControl (PID $PID)."
        fi
    fi
    rm -f "$RUN_FLAG"
    rm -f "$PID_FILE"
}


case "$1" in
    start)
        sudo ectool backlight 1 >/dev/null 2>&1
        stop_monitoring >/dev/null 2>&1
        if [ -f "$LOG_FILE" ] && [ "$(stat -c%s "$LOG_FILE")" -gt 32768 ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Truncated log file (exceeded 32KB)" | tee -a "$LOG_FILE"
        fi
        nohup "$0" __monitor__ >> "$LOG_FILE" 2>&1 &
        echo "${GREEN}$(date '+%Y-%m-%d %H:%M:%S') - SleepControl started in background. Output is logged to $LOG_FILE${RESET}" | tee -a "$LOG_FILE"
        ;;
    stop)
        sudo ectool backlight 1 >/dev/null 2>&1
        stop_monitoring
        echo "${YELLOW}$(date '+%Y-%m-%d %H:%M:%S') - SleepControl stopped.${RESET}." | tee -a "$LOG_FILE"
        ;;
    battery|power)
        MODE=$1
        BACKLIGHT_VAL=$2
        DELAY_VAL=$3

        if [ -n "$BACKLIGHT_VAL" ] && [ -n "$DELAY_VAL" ]; then
            if [[ "$BACKLIGHT_VAL" =~ ^[0-9]+$ ]] && [[ "$DELAY_VAL" =~ ^[0-9]+$ ]]; then
                if (( BACKLIGHT_VAL > DELAY_VAL )); then
                    echo "${RED}Backlight timeout cannot be greater than sleep delay.${RESET}"
                    exit 1
                fi
                if [ "$MODE" = "battery" ]; then
                    BATTERY_BACKLIGHT=$BACKLIGHT_VAL
                    BATTERY_DELAY=$DELAY_VAL
                else
                    POWER_BACKLIGHT=$BACKLIGHT_VAL
                    POWER_DELAY=$DELAY_VAL
                fi
                save_config
                echo "${GREEN}${BOLD}${MODE^}${RESET}${GREEN} backlight timeout set to ${BOLD}${BACKLIGHT_VAL} min${RESET}${GREEN}, sleep delay set to ${BOLD}${DELAY_VAL} min.${RESET}"
            else
                echo "${RED}Invalid values. Usage: sleepcontrol $MODE <backlight> <delay> (numbers only).${RESET}"
            fi
        elif [ -n "$BACKLIGHT_VAL" ]; then
            if [[ "$BACKLIGHT_VAL" =~ ^[0-9]+$ ]]; then
                if [ "$MODE" = "battery" ]; then
                    BATTERY_DELAY=$BACKLIGHT_VAL
                else
                    POWER_DELAY=$BACKLIGHT_VAL
                fi
                save_config
                echo "${GREEN}${BOLD}${MODE^}${RESET}${GREEN} sleep delay set to ${BOLD}${BACKLIGHT_VAL} minutes.${RESET}"
            else
                echo "${RED}Invalid value. Please enter a number.${RESET}"
            fi
        else
            load_config
            if [ "$MODE" = "battery" ]; then
                echo "Battery: Backlight = $BATTERY_BACKLIGHT min, Delay = $BATTERY_DELAY min"
            else
                echo "Power: Backlight = $POWER_BACKLIGHT min, Delay = $POWER_DELAY min"
            fi
        fi
        ;;
        startup)
        CONF_SOURCE="$INSTALL_DIR/sleepcontrol.conf"
        CONF_TARGET="/etc/init/sleepcontrol.conf"

        read -p "Do you want SleepControl to startup automatically? (y/n): " choice
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            if [ -f "$CONF_SOURCE" ]; then
                echo "Copying sleepcontrol.conf to /etc/init/..."
                sudo cp "$CONF_SOURCE" "$CONF_TARGET"
                echo "${GREEN}sleepcontrol.conf copied.${RESET}"
            else
                echo "${RED}sleepcontrol.conf not found at $CONF_SOURCE${RESET}"
            fi
        else
            echo "SleepControl will not startup automatically."
            sudo rm -f /etc/init/sleepcontrol.conf
        fi
        ;;
        status|"")
        load_config
        if [ -f "$RUN_FLAG" ]; then
            PID=$(cat "$PID_FILE")
            if ps -p "$PID" > /dev/null 2>&1; then
                echo "${GREEN}SleepControl Status: ENABLED (PID $PID)${RESET}"
                echo "${GREEN}SleepControl is running.${RESET}"
            else
                echo "${YELLOW}SleepControl Status: RUN FLAG PRESENT, but process not running${RESET}"
            fi
            echo ""
            echo "Sleep set for: ${GREEN}On Battery = $((BATTERY_DELAY)) minutes${RESET}, ${BLUE}On Power = $((POWER_DELAY)) minutes${RESET}"
            echo "Display timeout set for: ${GREEN}On Battery = $BATTERY_BACKLIGHT minutes${RESET}, ${BLUE}On Power = $POWER_BACKLIGHT minutes${RESET}"
        else
            echo "${RED}SleepControl Status: DISABLED${RESET}"
            echo "${RED}SleepControl is not running.${RESET}"
        fi
        ;;
    __monitor__)
        monitor_idle_activity
        ;;
        help)
            "$0" status
        ;;
    *)
        echo "${BLUE}# SleepControl Commands with examples"
        echo ""
        echo "sudo sleepcontrol                        # Show current SleepControl settings"
        echo "sudo sleepcontrol start                  # Start SleepControl"
        echo "sudo sleepcontrol stop                   # Stop SleepControl"
        echo "sudo sleepcontrol battery 15             # Sleep after 15 minutes when on battery "
        echo "sudo sleepcontrol power 60               # Sleep after 60 minutes when plugged in."
        echo "sudo sleepcontrol battery_backlight 10   # Turn off display after 15 mins when idling on battery."
        echo "sudo sleepcontrol power_backlight 30     # Turn off display after 60 mins when idling plugged-in."
        echo "sudo sleepcontrol startup                # Copy or Remove sleepcontrol.conf at: /etc/init/"
        echo "sudo sleepcontrol help                   # Help menu${RESET}"
        exit 0
        ;;
esac

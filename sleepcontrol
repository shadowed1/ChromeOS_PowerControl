#!/bin/bash
RED=$(tput setaf 1)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
BLUE=$(tput setaf 4)
MAGENTA=$(tput setaf 5)
CYAN=$(tput setaf 6)
BOLD=$(tput bold)
RESET=$(tput sgr0)

INSTALL_DIR_FILE="/usr/local/bin/.ChromeOS_PowerControl.install_dir"
if [ -f "$INSTALL_DIR_FILE" ]; then
    INSTALL_DIR=$(cat "$INSTALL_DIR_FILE")
else
    INSTALL_DIR="/usr/local/bin/ChromeOS_PowerControl"
fi
INSTALL_DIR="${INSTALL_DIR%/}"

CONFIG_FILE="$INSTALL_DIR/config.sh"
PID_FILE="$INSTALL_DIR/.sleepcontrol_pid"
RUN_FLAG="$INSTALL_DIR/.sleepcontrol_enabled"
LOG_FILE="/var/log/sleepcontrol.log"
BATTERY_STATUS_PATH="/sys/class/power_supply/BAT0/status"
SIM_FILE="/tmp/sleepcontrol.sim"
SIM_FILE_TMP="/tmp/sleepcontrol.sim.tmp"


DEFAULT_BATTERY_DELAY=14
DEFAULT_POWER_DELAY=30
DEFAULT_BATTERY_BACKLIGHT=4
DEFAULT_POWER_BACKLIGHT=10

BATTERY_DELAY=
POWER_DELAY=
BATTERY_BACKLIGHT=
POWER_BACKLIGHT=
audio_active=0

BATTERY_DELAY=$DEFAULT_BATTERY_DELAY
POWER_DELAY=$DEFAULT_POWER_DELAY
BATTERY_BACKLIGHT=$DEFAULT_BATTERY_BACKLIGHT
POWER_BACKLIGHT=$DEFAULT_POWER_BACKLIGHT

   load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
    validate_config
}

validate_config() {
    if [[ -z "$BATTERY_DELAY" || ! "$BATTERY_DELAY" =~ ^[0-9]+$ ]]; then
        BATTERY_DELAY=$DEFAULT_BATTERY_DELAY
    fi

    if [[ -z "$POWER_DELAY" || ! "$POWER_DELAY" =~ ^[0-9]+$ ]]; then
        POWER_DELAY=$DEFAULT_POWER_DELAY
    fi

    if [[ -z "$BATTERY_BACKLIGHT" || ! "$BATTERY_BACKLIGHT" =~ ^[0-9]+$ ]]; then
        BATTERY_BACKLIGHT=$DEFAULT_BATTERY_BACKLIGHT
    fi

    if [[ -z "$POWER_BACKLIGHT" || ! "$POWER_BACKLIGHT" =~ ^[0-9]+$ ]]; then
        POWER_BACKLIGHT=$DEFAULT_POWER_BACKLIGHT
    fi
}

save_config() {
    validate_config

    sed -i "s/^BATTERY_DELAY=.*/BATTERY_DELAY=$BATTERY_DELAY/" "$CONFIG_FILE" || echo "BATTERY_DELAY=$BATTERY_DELAY" >> "$CONFIG_FILE"
    sed -i "s/^POWER_DELAY=.*/POWER_DELAY=$POWER_DELAY/" "$CONFIG_FILE" || echo "POWER_DELAY=$POWER_DELAY" >> "$CONFIG_FILE"
    sed -i "s/^BATTERY_BACKLIGHT=.*/BATTERY_BACKLIGHT=$BATTERY_BACKLIGHT/" "$CONFIG_FILE" || echo "BATTERY_BACKLIGHT=$BATTERY_BACKLIGHT" >> "$CONFIG_FILE"
    sed -i "s/^POWER_BACKLIGHT=.*/POWER_BACKLIGHT=$POWER_BACKLIGHT/" "$CONFIG_FILE" || echo "POWER_BACKLIGHT=$POWER_BACKLIGHT" >> "$CONFIG_FILE"
}

load_config

save_sim_times() {
    local -n arr=$1  # pass array by name
    : > "$SIM_FILE_TMP"  # empty tmp file
    for ts in "${arr[@]}"; do
        echo "$ts" >> "$SIM_FILE_TMP"
    done
    mv "$SIM_FILE_TMP" "$SIM_FILE"
}

load_sim_times() {
    local -n arr=$1
    arr=()
    if [ -f "$SIM_FILE" ]; then
        mapfile -t arr < "$SIM_FILE"
    fi
}

monitor_idle_activity() {
    load_config
    touch "$RUN_FLAG"
    echo $$ > "$PID_FILE"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - sleepcontrol started (PID $$)." >> "$LOG_FILE"

    local backlight_off=0
    local last_reload_time=0
    local delay_minutes
    local active=1
    local sim_pid=
    local -a last_simulated_times=()
    local sim_file="/tmp/sleepcontrol.sim"
    local power_backlight_ts=
    local battery_backlight_ts=
    local audio_active=0

    while read -r line; do
        if echo "$line" | grep -q "Audio activity started"; then
            audio_active=1
        elif echo "$line" | grep -q "Audio activity stopped"; then
            audio_active=0
        fi

        if [ -f "$BATTERY_STATUS_PATH" ]; then
            status=$(cat "$BATTERY_STATUS_PATH")
            if [ "$status" = "Discharging" ]; then
                delay_minutes=$BATTERY_DELAY
                backlight_delay=$BATTERY_BACKLIGHT
            else
                delay_minutes=$POWER_DELAY
                backlight_delay=$POWER_BACKLIGHT
            fi
        else
            delay_minutes=$DEFAULT_POWER_DELAY
            backlight_delay=$POWER_BACKLIGHT
        fi

        now_epoch=$(date +%s)

        if [ "$audio_active" -eq 1 ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Audio activity active, skipping backlight timeout." >> "$LOG_FILE"
            battery_backlight_ts=$now_epoch
            power_backlight_ts=$now_epoch
            continue
        fi

        if [ "$status" = "Discharging" ]; then
            if [ -z "$battery_backlight_ts" ]; then
                battery_backlight_ts=$now_epoch
            elif (( now_epoch - battery_backlight_ts >= BATTERY_BACKLIGHT * 60 )); then
                if [ "$backlight_off" -eq 0 ]; then
                    sudo ectool backlight 0
                    backlight_off=1
                    echo "$(date '+%Y-%m-%d %H:%M:%S') - Turned display off due to battery backlight timeout (${BATTERY_BACKLIGHT} min)" >> "$LOG_FILE"
                fi
                echo "$(date '+%Y-%m-%d %H:%M:%S') - Prevented backlight timeout via HandleUserActivity (battery backlight delay $BATTERY_BACKLIGHT min)." >> "$LOG_FILE"
                battery_backlight_ts=$now_epoch
            fi
            power_backlight_ts=""
        else
            if [ -z "$power_backlight_ts" ]; then
                power_backlight_ts=$now_epoch
            elif (( now_epoch - power_backlight_ts >= POWER_BACKLIGHT * 60 )); then
                if [ "$backlight_off" -eq 0 ]; then
                    sudo ectool backlight 0
                    backlight_off=1
                    echo "$(date '+%Y-%m-%d %H:%M:%S') - Turned display off due to power backlight timeout (${POWER_BACKLIGHT} min)" >> "$LOG_FILE"
                fi
                echo "$(date '+%Y-%m-%d %H:%M:%S') - Prevented backlight timeout via HandleUserActivity (power backlight delay $POWER_BACKLIGHT min)." >> "$LOG_FILE"
                power_backlight_ts=$now_epoch
            fi
            battery_backlight_ts=""
        fi

        now=$(date +%s)
        if (( now - last_reload_time >= 120 )); then
            load_config
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Config reloaded: BATTERY_DELAY=$BATTERY_DELAY, POWER_DELAY=$POWER_DELAY" >> "$LOG_FILE"
            last_reload_time=$now
        fi

        if [ ! -f "$RUN_FLAG" ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - sleepcontrol stopped, exiting loop." >> "$LOG_FILE"
            [ -n "$sim_pid" ] && kill "$sim_pid" 2>/dev/null
            rm -f "$PID_FILE"
            exit 0
        fi

        if echo "$line" | grep -q "User activity stopped"; then
            if [ "$active" -eq 1 ]; then
                sleep 1
                active=0

                if [ -n "$sim_pid" ] && kill -0 "$sim_pid" 2>/dev/null; then
                    echo "$(date '+%Y-%m-%d %H:%M:%S') - Simulate loop already running (PID $sim_pid), skipping duplicate launch." >> "$LOG_FILE"
                    continue
                fi

                (
                    end=$((SECONDS + delay_minutes * 60))
                    while [ $SECONDS -lt $end ]; do
                        dbus-send --system --type=method_call \
                            --dest=org.chromium.PowerManager \
                            /org/chromium/PowerManager \
                            org.chromium.PowerManager.HandleUserActivity \
                            int32:0 int32:0
                        ts=$(date +%s)
                        last_simulated_times+=("$ts")
                        if [ "${#last_simulated_times[@]}" -gt 10 ]; then
                            last_simulated_times=("${last_simulated_times[@]: -10}")
                        fi
                        printf "%s\n" "${last_simulated_times[@]}" > "$sim_file"
                        sleep 1
                    done
                ) &
                sim_pid=$!
            fi
        elif echo "$line" | grep -q "User activity reported"; then
            if [[ "$line" =~ ([0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}) ]]; then
                reported_time_utc="${BASH_REMATCH[1]}"
                reported_epoch=$(date -u -d "$reported_time_utc" +%s 2>/dev/null)
                matched_recent_sim=0

                if [ -f "$sim_file" ]; then
                    readarray -t last_simulated_times < "$sim_file"
                fi

                for sim_ts in "${last_simulated_times[@]}"; do
                    diff=$((reported_epoch - sim_ts))
                    if (( diff >= -10 && diff <= 10 )); then
                        matched_recent_sim=1
                        break
                    fi
                done

                echo "$(date '+%Y-%m-%d %H:%M:%S') - Detected user activity log time $reported_epoch, matched_recent_sim=$matched_recent_sim" >> "$LOG_FILE"

                if [ "$matched_recent_sim" -eq 0 ]; then
                    if [ "$active" -eq 0 ]; then
                        active=1
                        [ -n "$sim_pid" ] && kill "$sim_pid" 2>/dev/null && sim_pid=
                        echo "$(date '+%Y-%m-%d %H:%M:%S') - Waiting for user to go idle again." >> "$LOG_FILE"
                    fi

                    # Turn display on if needed
                    if [ "$backlight_off" -eq 1 ]; then
                        sudo ectool backlight 1
                        backlight_off=0
                        echo "$(date '+%Y-%m-%d %H:%M:%S') - Real user activity detected, turned display back on." >> "$LOG_FILE"
                    fi

                    # Reset the timestamp so we don’t turn it off again too quickly
                    if [ "$status" = "Discharging" ]; then
                        battery_backlight_ts=$now_epoch
                    else
                        power_backlight_ts=$now_epoch
                    fi
                fi
            fi
        fi
    done < <(tail -Fn0 /var/log/power_manager/powerd.LATEST)
}


stop_monitoring() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            kill "$PID" && echo "$(date '+%Y-%m-%d %H:%M:%S') - ${RED}sleepcontrol stopped (PID $PID).${RESET}" | tee -a "$LOG_FILE"
        fi
        rm -f "$PID_FILE"
    else
        echo "${YELLOW}sleepcontrol is not running.${RESET}"
    fi
    rm -f "$RUN_FLAG"
}

case "$1" in
    start)
        sudo ectool backlight 1
        stop_monitoring >/dev/null 2>&1
        if [ -f "$LOG_FILE" ] && [ "$(stat -c%s "$LOG_FILE")" -gt 32768 ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Truncated log file (exceeded 32KB)." >> "$LOG_FILE"
        fi
       if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            sudo bash "$INSTALL_DIR/sleepcontrol" stop
            sudo bash "$INSTALL_DIR/sleepcontrol" start
        fi

        nohup "$0" __monitor__ >> "$LOG_FILE" 2>&1 &
        echo $! > "$PID_FILE"
        touch "$RUN_FLAG"
        ;;
    stop)
        sudo ectool backlight 1
        stop_monitoring
        ;;
        battery)
        if [ -n "$2" ]; then
            if [[ "$2" =~ ^[0-9]+$ ]]; then
                user_input=$2
                actual_delay=$((user_input - 6))
                if (( actual_delay < 7 )); then
                    echo "${RED}Please enter a larger value, this is lower than ChromeOS' sleep.${RESET}"
                fi
                BATTERY_DELAY=$actual_delay
                save_config
                echo "${GREEN}When ${RESET}${GREEN}${BOLD}idling on battery${RESET}${GREEN}, ChromeOS will sleep in $user_input minutes.${GREEN}"
            else
                echo "Invalid delay value. Please enter a positive integer."
            fi
        else
            load_config
            echo "Battery delay: $((BATTERY_DELAY + 6)) minutes."
        fi
        ;;
        power)
    if [ -n "$2" ]; then
        if [[ "$2" =~ ^[0-9]+$ ]]; then
            user_input=$2
            actual_delay=$((user_input - 8))
            if (( actual_delay < 9 )); then
                echo "${RED}Please enter a larger value, this is lower than ChromeOS' sleep."
            fi
            POWER_DELAY=$actual_delay
            save_config
            echo "${GREEN}When ${RESET}${GREEN}${BOLD}idling plugged${RESET}${GREEN} in ChromeOS will sleep in $user_input minutes.${RESET}"
        else
            echo "${RED}Invalid delay value. Please enter a positive integer.${RESET}"
        fi
    else
        load_config
        echo "Power delay: $((POWER_DELAY + 8)) minutes."
    fi
    ;;
    battery_backlight)
        if [ -n "$2" ]; then
            if [[ "$2" =~ ^[0-9]+$ ]]; then
                BATTERY_BACKLIGHT=$2
                save_config
                echo "${GREEN}Battery backlight timeout set to ${BOLD}$BATTERY_BACKLIGHT${RESET}${GREEN} minutes.${RESET}"
            else
                echo "${RED}Invalid value. Enter a number in minutes.${RESET}"
            fi
        else
            load_config
            echo "Battery backlight timeout: $BATTERY_BACKLIGHT minutes"
        fi
        ;;
    power_backlight)
        if [ -n "$2" ]; then
            if [[ "$2" =~ ^[0-9]+$ ]]; then
                POWER_BACKLIGHT=$2
                save_config
                echo "${GREEN}Power backlight timeout set to ${BOLD}$POWER_BACKLIGHT${RESET}${GREEN} minutes.${RESET}"
            else
                echo "${RED}Invalid value. Enter a number in minutes.${RESET}"
            fi
        else
            load_config
            echo "Power backlight timeout: $POWER_BACKLIGHT minutes"
        fi
        ;;


        startup)
        CONF_SOURCE="$INSTALL_DIR/sleepcontrol.conf"
        CONF_TARGET="/etc/init/sleepcontrol.conf"

        read -p "Do you want SleepControl to startup automatically? (y/n): " choice
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            if [ -f "$CONF_SOURCE" ]; then
                echo "Copying sleepcontrol.conf to /etc/init/..."
                sudo cp "$CONF_SOURCE" "$CONF_TARGET"
                echo "${GREEN}sleepcontrol.conf copied.${RESET}"
            else
                echo "${RED}sleepcontrol.conf not found at $CONF_SOURCE${RESET}"
            fi
        else
            echo "SleepControl will not startup automatically."
            sudo rm -f /etc/init/sleepcontrol.conf
        fi
        ;;
    status|"")
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            load_config
            echo "${GREEN}SleepControl is running.${RESET}"
            echo ""
            echo "Sleep set for: ${GREEN}On Battery = $((BATTERY_DELAY + 6)) minutes${RESET}, ${BLUE}On Power = $((POWER_DELAY + 8)) minutes${RESET}"
            echo "Display timeout set for: ${GREEN}On Battery = $BATTERY_BACKLIGHT minutes${RESET}, ${BLUE}On Power = $POWER_BACKLIGHT minutes${RESET}"
        else
            load_config
            echo "${RED}SleepControl is not running.${RESET}"
            echo ""
            echo "Sleep set for: ${GREEN}On Battery = $((BATTERY_DELAY + 6)) minutes${RESET}, ${BLUE}On Power = $((POWER_DELAY + 8)) minutes${RESET}"
            echo "Display timeout set for: ${GREEN}On Battery = $BATTERY_BACKLIGHT minutes${RESET}, ${BLUE}On Power = $POWER_BACKLIGHT minutes${RESET}"
        fi
        ;;
    __monitor__)
        monitor_idle_activity
        ;;
         help)
        "$0"
        ;;
    *)
        echo "${BLUE}# SleepControl Commands with examples"
        echo ""
        echo "sudo sleepcontrol                        # Show current SleepControl settings"
        echo "sudo sleepcontrol start                  # Start SleepControl"
        echo "sudo sleepcontrol stop                   # Stop SleepControl"
        echo "sudo sleepcontrol battery 15             # Sleep after 15 minutes when on battery "
        echo "sudo sleepcontrol power 60               # Sleep after 60 minutes when plugged in."
        echo "sudo sleepcontrol battery_backlight 10   # Turn off display after 15 mins when idling on battery."
        echo "sudo sleepcontrol power_backlight 30     # Turn off display after 60 mins when idling plugged-in."
        echo "sudo sleepcontrol startup                # Copy or Remove fancontrol.conf at: /etc/init/"
        echo "sudo sleepcontrol help                   # Help menu${RESET}"
        exit 1
        ;;
esac

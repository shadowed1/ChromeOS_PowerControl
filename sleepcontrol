#!/bin/bash
RED=$(tput setaf 1)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
BLUE=$(tput setaf 4)
MAGENTA=$(tput setaf 5)
CYAN=$(tput setaf 6)
BOLD=$(tput bold)
RESET=$(tput sgr0)

INSTALL_DIR_FILE="/usr/local/bin/.ChromeOS_PowerControl.install_dir"
if [ -f "$INSTALL_DIR_FILE" ]; then
    INSTALL_DIR=$(cat "$INSTALL_DIR_FILE")
else
    INSTALL_DIR="/usr/local/bin/ChromeOS_PowerControl"
fi
INSTALL_DIR="${INSTALL_DIR%/}"

CONFIG_FILE="$INSTALL_DIR/config.sh"
PID_FILE="$INSTALL_DIR/.sleepcontrol_pid"
RUN_FLAG="$INSTALL_DIR/.sleepcontrol_enabled"
LOG_FILE="/var/log/sleepcontrol.log"
BATTERY_STATUS_PATH="/sys/class/power_supply/BAT0/status"

DEFAULT_BATTERY_DELAY=14
DEFAULT_POWER_DELAY=30

BATTERY_DELAY=
POWER_DELAY=

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi

    BATTERY_DELAY="${BATTERY_DELAY:-$DEFAULT_BATTERY_DELAY}"
    POWER_DELAY="${POWER_DELAY:-$DEFAULT_POWER_DELAY}"
}

save_config() {
    {
        echo "BATTERY_DELAY=$BATTERY_DELAY"
        echo "POWER_DELAY=$POWER_DELAY"
    } > "$CONFIG_FILE"
}

simulate_activity_loop() {
    local delay_minutes=$1
    local end=$((SECONDS + delay_minutes * 60))
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Starting simulate_activity_loop for $delay_minutes minutes." | tee -a "$LOG_FILE"
    while [ $SECONDS -lt $end ]; do
        dbus-send --system --type=method_call \
            --dest=org.chromium.PowerManager \
            /org/chromium/PowerManager \
            org.chromium.PowerManager.HandleUserActivity \
            int32:0 int32:0
        sleep 120
    done
    echo "$(date '+%Y-%m-%d %H:%M:%S') - simulate_activity_loop ended." | tee -a "$LOG_FILE"
}

monitor_idle_activity() {
    touch "$RUN_FLAG"
    echo $$ > "$PID_FILE"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - sleepcontrol started (PID $$)." | tee -a "$LOG_FILE"

    local last_reload_time=0
    local delay_minutes
    local active=1
    local sim_pid=
    local -a last_simulated_times=()

    tail -Fn0 /var/log/power_manager/powerd.LATEST | while read -r line; do

        if [ ! -f "$RUN_FLAG" ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - sleepcontrol stopped, exiting loop." | tee -a "$LOG_FILE"
            [ -n "$sim_pid" ] && kill "$sim_pid" 2>/dev/null
            rm -f "$PID_FILE"
            exit 0
        fi

        now=$(date +%s)
        if (( now - last_reload_time >= 120 )); then
            load_config
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Config reloaded: BATTERY_DELAY=$BATTERY_DELAY, POWER_DELAY=$POWER_DELAY" | tee -a "$LOG_FILE"
            last_reload_time=$now
        fi

        if [ -f "$BATTERY_STATUS_PATH" ]; then
            status=$(cat "$BATTERY_STATUS_PATH")
            if [ "$status" = "Discharging" ]; then
                delay_minutes=$BATTERY_DELAY
            else
                delay_minutes=$POWER_DELAY
            fi
        else
            delay_minutes=$DEFAULT_POWER_DELAY
        fi

        # Simulate activity
        if echo "$line" | grep -q "User activity stopped"; then
            if [ "$active" -eq 1 ]; then
                active=0
                (
                    end=$((SECONDS + delay_minutes * 60))
                    while [ $SECONDS -lt $end ]; do
                        dbus-send --system --type=method_call \
                            --dest=org.chromium.PowerManager \
                            /org/chromium/PowerManager \
                            org.chromium.PowerManager.HandleUserActivity \
                            int32:0 int32:0
                        ts=$(date -u +"%s")
                        last_simulated_times+=("$ts")
                        if [ "${#last_simulated_times[@]}" -gt 10 ]; then
                            last_simulated_times=("${last_simulated_times[@]: -10}")
                        fi
                        sleep 120
                    done
                ) &
                sim_pid=$!
                echo "$(date '+%Y-%m-%d %H:%M:%S') - User inactive, started simulate_activity_loop (PID $sim_pid)." | tee -a "$LOG_FILE"
            fi
        elif echo "$line" | grep -q "User activity reported"; then
            if [[ "$line" =~ ([0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}) ]]; then
                reported_time_utc="${BASH_REMATCH[1]}"
                reported_epoch=$(date -u -d "$reported_time_utc" +%s 2>/dev/null)
                matched_recent_sim=0

                for sim_ts in "${last_simulated_times[@]}"; do
                    diff=$((reported_epoch - sim_ts))
                    if (( diff >= 0 && diff <= 5 )); then
                        matched_recent_sim=1
                        break
                    fi
                done

                if [ "$matched_recent_sim" -eq 0 ]; then
                    # Detect real user activity so fake activity can stop. 
                    if [ "$active" -eq 0 ]; then
                        active=1
                        if [ -n "$sim_pid" ]; then
                            kill "$sim_pid" 2>/dev/null
                            echo "$(date '+%Y-%m-%d %H:%M:%S') - Real user active, killed simulate_activity_loop (PID $sim_pid)." | tee -a "$LOG_FILE"
                            sim_pid=
                        fi
                        echo "$(date '+%Y-%m-%d %H:%M:%S') - Waiting for user to go idle again." | tee -a "$LOG_FILE"
                    fi
                fi
            fi
        fi
    done
}

stop_monitoring() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            kill "$PID" && echo "$(date '+%Y-%m-%d %H:%M:%S') - sleepcontrol stopped (PID $PID)." | tee -a "$LOG_FILE"
        fi
        rm -f "$PID_FILE"
    else
        echo "${YELLOW}sleepcontrol is not running.${RESET}"
    fi
    rm -f "$RUN_FLAG"
}

case "$1" in
    start)
        if [ -f "$LOG_FILE" ] && [ "$(stat -c%s "$LOG_FILE")" -gt 32768 ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') - Truncated log file (exceeded 32KB)." | tee -a "$LOG_FILE"
            > "$LOG_FILE"
        fi

        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "sleepcontrol is already running."
            exit 1
        fi

        nohup "$0" __monitor__ >> "$LOG_FILE" 2>&1 &
        echo $! > "$PID_FILE"
        touch "$RUN_FLAG"
        echo "sleepcontrol started."
        ;;
    stop)
        stop_monitoring
        ;;
        battery)
        if [ -n "$2" ]; then
            if [[ "$2" =~ ^[0-9]+$ ]]; then
                local user_input=$2
                local actual_delay=$((user_input - 6))  # 6m30s rounded down to 6
                if (( actual_delay < 7 )); then
                    echo "ChromeOS has a built in 6m30s timer for battery; making a -7m offset for ease-of-use."
                    exit 1
                fi
                BATTERY_DELAY=$actual_delay
                save_config
                echo "${GREEN}Battery sleep delayed by $user_input minutes.${GREEN}"
            else
                echo "Invalid delay value. Please enter a positive integer."
                exit 1
            fi
        else
            load_config
            echo "Battery delay: $((BATTERY_DELAY + 6)) minutes."
        fi
        ;;
        power)
        if [ -n "$2" ]; then
            if [[ "$2" =~ ^[0-9]+$ ]]; then
                local user_input=$2
                local actual_delay=$((user_input - 8))  # 8m30s rounded down to 8
                if (( actual_delay < 9 )); then
                    echo "ChromeOS has a built in 8m30s timer for power; making a -9m offset for ease-of-use."
                    exit 1
                fi
                POWER_DELAY=$actual_delay
                save_config
                echo "${GREEN}Power sleep delayed by $user_input minutes.${RESET}"
            else
                echo "Invalid delay value. Please enter a positive integer."
                exit 1
            fi
        else
            load_config
            echo "Power delay: $((POWER_DELAY + 8)) minutes."
        fi
        ;;
        startup)
        CONF_SOURCE="$INSTALL_DIR/sleepcontrol.conf"
        CONF_TARGET="/etc/init/sleepcontrol.conf"

        read -p "Do you want SleepControl to startup automatically? (y/n): " choice
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            if [ -f "$CONF_SOURCE" ]; then
                echo "Copying sleepcontrol.conf to /etc/init/..."
                sudo cp "$CONF_SOURCE" "$CONF_TARGET"
                echo "${GREEN}sleepcontrol.conf copied.${RESET}"
            else
                echo "${RED}sleepcontrol.conf not found at $CONF_SOURCE${RESET}"
            fi
        else
            echo "SleepControl will not startup automatically."
            sudo rm -r /etc/init/sleepcontrol.conf
        fi
        ;;
    status|"")
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            load_config
            echo "${GREEN}SleepControl is running.${RESET}"
            echo ""
            echo "Sleep delayed: Battery=$BATTERY_DELAY, Power=$POWER_DELAY"
        else
            load_config
            echo "${YELLOW}sleepcontrol is not running.${RESET}"
            echo ""
            echo "Sleep delayed: Battery=$BATTERY_DELAY, Power=$POWER_DELAY"
        fi
        ;;
    __monitor__)
        monitor_idle_activity
        ;;
    *)
        echo "${BLUE}# SleepControl Commands with examples"
        echo ""
        echo "sudo sleepcontrol                     # Show current GPU info and frequency"
        echo "sudo sleepcontrol start               # Start SleepControl"
        echo "sudo sleepcontrol stop                # Stop SleepControl"
        echo "sudo sleepcontrol battery 15          # Delays sleep by 15 minutes when on battery "
        echo "sudo sleepcontrol power 60            # Delays sleep by 60 minutes when plugged in." 
        echo "sudo sleepcontrol startup             # Copy or Remove fanontrol.conf at: /etc/init/"
        echo "sudo sleepcontrol help                # Help menu${RESET}"
        exit 1
        ;;
esac

#!/bin/bash

INSTALL_DIR_FILE=/usr/local/bin/ChromeOS_PowerControl.install_dir
if [ -f "$INSTALL_DIR_FILE" ]; then
    INSTALL_DIR=$(cat "$INSTALL_DIR_FILE")
else
    INSTALL_DIR="$INSTALL_DIR"
fi

INSTALL_DIR="${INSTALL_DIR%/}"
CONFIG_FILE="$INSTALL_DIR/config.sh"
ZONE_PATH="/sys/class/thermal/thermal_zone0/temp"
RUN_FLAG_FAN="$INSTALL_DIR/.fan_curve_running"
PID_FILE_FAN="$INSTALL_DIR/.fan_curve_pid"
FAN_LOG_FILE="var/log/fancontrol.log"
MONITOR_PID_FILE="/tmp/powercontrol_tail_fan_monitor.pid"

DEFAULT_FAN_MIN_TEMP=48   # Minimum fan control temperature
DEFAULT_FAN_MAX_TEMP=81   # Maximum fan control temperature
DEFAULT_MIN_FAN=0         # Minimum fan speed
DEFAULT_MAX_FAN=100       # Maximum fan speed
DEFAULT_SLEEP_INTERVAL=3   
DEFAULT_STEP_UP=20        
DEFAULT_STEP_DOWN=1

SLEEP_INTERVAL=$DEFAULT_SLEEP_INTERVAL
STEP_UP=$DEFAULT_STEP_UP
STEP_DOWN=$DEFAULT_STEP_DOWN

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    else
        FAN_MIN_TEMP=$DEFAULT_FAN_MIN_TEMP
        FAN_MAX_TEMP=$DEFAULT_FAN_MAX_TEMP
        MIN_FAN=$DEFAULT_MIN_FAN
        MAX_FAN=$DEFAULT_MAX_FAN
        SLEEP_INTERVAL=$DEFAULT_SLEEP_INTERVAL
        STEP_UP=$DEFAULT_STEP_UP
        STEP_DOWN=$DEFAULT_STEP_DOWN
        save_config
    fi
}

save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" <<EOF
FAN_MIN_TEMP=$FAN_MIN_TEMP
FAN_MAX_TEMP=$FAN_MAX_TEMP
MIN_FAN=$MIN_FAN
MAX_FAN=$MAX_FAN
SLEEP_INTERVAL=$SLEEP_INTERVAL
STEP_UP=$STEP_UP
STEP_DOWN=$STEP_DOWN
EOF
}

# === Fan logic with hysteresis ===
cleanup() {
    echo "Restoring automatic fan control..." | tee -a "$FAN_LOG_FILE"
    sudo ectool autofanctrl
    rm -f "$RUN_FLAG_BATTERY" "$PID_FILE_FAN"
    exit 0
}

run_loop() {
    sudo ectool autofanctrl
    echo "Fan curve started. Press Ctrl+C to stop." | tee -a "$FAN_LOG_FILE"

    local last_duty=-1

    while [ -f "$RUN_FLAG_BATTERY" ]; do
        if [ ! -f "$ZONE_PATH" ]; then
            echo "Thermal zone not found: $ZONE_PATH" | tee -a "$FAN_LOG_FILE"
            cleanup
        fi

        load_config

        RAW_TEMP=$(cat "$ZONE_PATH")
        TEMP_C=$((RAW_TEMP / 1000))

        if (( TEMP_C <= FAN_MIN_TEMP )); then
            DUTY=$MIN_FAN
        elif (( TEMP_C >= FAN_MAX_TEMP )); then
            DUTY=$MAX_FAN
        else
            RANGE=$((FAN_MAX_TEMP - FAN_MIN_TEMP))
            OFFSET=$((TEMP_C - FAN_MIN_TEMP))
            DUTY=$((MIN_FAN + (OFFSET * (MAX_FAN - MIN_FAN) / RANGE)))
        fi

        # Apply hysteresis / gradual ramping with asymmetric steps
        if (( last_duty < 0 )); then
            target_duty=$DUTY
        else
            target_duty=$DUTY
            if (( target_duty > last_duty + STEP_UP )); then
                target_duty=$((last_duty + STEP_UP))
            elif (( target_duty < last_duty - STEP_DOWN )); then
                target_duty=$((last_duty - STEP_DOWN))
            fi
        fi

        KICKSTART_DUTY=50

        echo "Temp: ${TEMP_C}°C -> Fan Duty: ${target_duty}%" >> "$FAN_LOG_FILE"

        if (( last_duty > 0 && target_duty == 0 )); then
            echo "Applying kickstart at ${KICKSTART_DUTY}% before setting to 0%" >> "$FAN_LOG_FILE"
            sudo ectool fanduty "$KICKSTART_DUTY"
            sleep 1
            sudo ectool fanduty 0
        else
            sudo ectool fanduty "$target_duty"
        fi

        last_duty=$target_duty

        sleep "$SLEEP_INTERVAL"
    done

    cleanup
}

# === Start / Stop / Monitor ===
start() {
    "$0" stop >/dev/null 2>&1

    if [ -f "$FAN_LOG_FILE" ] && [ "$(stat -c%s "$FAN_LOG_FILE")" -gt 32768 ]; then
        echo "Truncated log file (exceeded 32KB)" > "$FAN_LOG_FILE"
    fi

    nohup "$0" __monitor__ >> "$FAN_LOG_FILE" 2>&1 &
    echo "FanControl started in background. Output is logged to $FAN_LOG_FILE"
}

stop() {
    if [ -f "$PID_FILE_FAN" ]; then
        PID=$(cat "$PID_FILE_FAN")
        echo "Stopping fan curve (PID $PID)..." | tee -a "$FAN_LOG_FILE"
        rm -f "$RUN_FLAG_BATTERY"
        kill "$PID" 2>/dev/null
        sleep 1
    fi
    sudo ectool fanduty 50
    sleep 1
    echo "Restoring automatic fan control..." | tee -a "$FAN_LOG_FILE"
    sudo ectool autofanctrl
    rm -f "$RUN_FLAG_BATTERY" "$PID_FILE_FAN"
}

monitor() {
    if [ -f "$MONITOR_PID_FILE" ]; then
        MONITOR_PID=$(cat "$MONITOR_PID_FILE")
        if ps -p "$MONITOR_PID" > /dev/null 2>&1; then
            echo "Stopping monitor (PID $MONITOR_PID)..."
            kill "$MONITOR_PID"
            rm -f "$MONITOR_PID_FILE"
            exit 0
        else
            echo "Stale PID file found. Removing."
            rm -f "$MONITOR_PID_FILE"
        fi
    fi

    tail -fn +1 "$FAN_LOG_FILE" &
    echo $! > "$MONITOR_PID_FILE"
    echo "Monitor started (PID $!)"
}

# === Config Setters ===
fan_min_temp() {
    if [[ "$2" =~ ^[0-9]+$ ]]; then
        load_config
        FAN_MIN_TEMP=$2
        save_config
        echo "Min temp set to $FAN_MIN_TEMP°C"
    else
        echo "Usage: $0 min_temp <number>"
    fi
}

fan_max_temp() {
    if [[ "$2" =~ ^[0-9]+$ ]] && (( $2 <= 90 )); then
        load_config
        FAN_MAX_TEMP=$2
        save_config
        echo "Max temp set to $FAN_MAX_TEMP°C"
    else
        echo "Usage: $0 max_temp <number (<=90)>"
    fi
}

min_fan() {
    if [[ "$2" =~ ^[0-9]+$ ]] && (( $2 >= 0 && $2 <= 100 )); then
        load_config
        if (( MAX_FAN > $2 )); then
            MIN_FAN=$2
            save_config
            echo "Min fan set to $MIN_FAN%"
        else
            echo "Error: MIN_FAN must be less than MAX_FAN ($MAX_FAN)"
        fi
    else
        echo "Usage: $0 min_fan <0-100>"
    fi
}

max_fan() {
    if [[ "$2" =~ ^[0-9]+$ ]] && (( $2 >= 0 && $2 <= 100 )); then
        load_config
        if (( $2 > MIN_FAN )); then
            MAX_FAN=$2
            save_config
            echo "Max fan set to $MAX_FAN%"
        else
            echo "Error: MAX_FAN must be greater than MIN_FAN ($MIN_FAN)"
        fi
    else
        echo "Usage: $0 max_fan <0-100>"
    fi
}

set_sleep_interval() {
    if [[ "$2" =~ ^[0-9]+$ ]] && (( $2 >= 1 && $2 <= 10 )); then
        load_config
        SLEEP_INTERVAL=$2
        save_config
        echo "Sleep interval set to $SLEEP_INTERVAL seconds"
    else
        echo "Usage: $0 update <sleep_interval_seconds (1-10)>"
    fi
}

set_stepup() {
    if [[ "$2" =~ ^[0-9]+$ ]] && (( $2 >= 1 && $2 <= 100 )); then
        load_config
        STEP_UP=$2
        save_config
        echo "Step-up size set to $STEP_UP%"
    else
        echo "Usage: $0 stepup <step_size_percent (1-100)>"
    fi
}

set_stepdown() {
    if [[ "$2" =~ ^[0-9]+$ ]] && (( $2 >= 1 && $2 <= 100 )); then
        load_config
        STEP_DOWN=$2
        save_config
        echo "Step-down size set to $STEP_DOWN%"
    else
        echo "Usage: $0 stepdown <step_size_percent (1-100)>"
    fi
}

show_help() {
    load_config
    echo "FanControl Script - Available Commands:"
    echo
    echo "  start                 Start custom fan curve."
    echo "  stop                  Stop fancontrol and restore autofanctrl"
    echo "  monitor               Toggle log monitor on/off"
    echo "  min_temp <°C>         Set minimum temperature (Celsius)"
    echo "  max_temp <°C>         Set maximum temperature (Celsius, max 90)"
    echo "  min_fan <0–100>       Set fan duty at min temp"
    echo "  max_fan <0–100>       Set fan duty at max temp (must be > min_fan)"
    echo "  update <seconds>      Set sleep interval between fan checks (1-10)"
    echo "  stepup <percent>      Set fan speed increase step size (1-100)"
    echo "  stepdown <percent>    Set fan speed decrease step size (1-100)"
    echo "  startup 0|1           Toggle 1 (on) 0 (off) for starting on boot."
    echo "  help                  Show this help message"
}

case "$1" in
    start) start ;;
    stop) stop ;;
    monitor) monitor ;;
    min_temp) fan_min_temp "$@" ;;
    max_temp) fan_max_temp "$@" ;;
    min_fan)  min_fan "$@" ;;
    max_fan)  max_fan "$@" ;;
    update)   set_sleep_interval "$@" ;;
    stepup)   set_stepup "$@" ;;
    stepdown) set_stepdown "$@" ;;
    __monitor__)
        echo $$ > "$PID_FILE_FAN"
        touch "$RUN_FLAG_BATTERY"
        run_loop
        ;;
        startup)
        CONF_SOURCE="$INSTALL_DIR/fancontrol.conf"
        CONF_TARGET="/etc/init/fancontrol.conf"

        if [ "$2" == "1" ]; then
            if [ -f "$CONF_SOURCE" ]; then
                echo "Copying fancontrol.conf to /etc/init/..."
                sudo cp "$CONF_SOURCE" "$CONF_TARGET"
                echo "Startup enabled."
            else
                echo "fancontrol.conf not found at $CONF_SOURCE"
                exit 1
            fi
        elif [ "$2" == "0" ]; then
            if [ -f "$CONF_TARGET" ]; then
                echo "Removing /etc/init/fancontrol.conf..."
                sudo rm -f "$CONF_TARGET"
                echo "Startup disabled."
            else
                echo "/etc/init/fancontrol.conf not found."
            fi
        else
            echo "Usage: $0 startup 1   # Enable startup"
            echo "       $0 startup 0   # Disable startup"
            exit 1
        fi
        ;;
    ""|status)
        echo "FanControl Status:"
        if [ -f "$RUN_FLAG_BATTERY" ]; then
            PID=$(cat "$PID_FILE_FAN")
            if ps -p "$PID" > /dev/null 2>&1; then
                echo "  Status: ENABLED (PID $PID)"
            else
                echo "  Status: RUN FLAG PRESENT, but process not running"
            fi
        else
            echo "  Status: DISABLED"
        fi
        echo
        echo "Hardware Info:"
        echo
        sudo ectool pwmgetnumfans
        sudo ectool pwmgetfanrpm all
        echo "Fan curve: $FAN_MIN_TEMP°C = ${MIN_FAN}%, $FAN_MAX_TEMP°C = ${MAX_FAN}%"
        echo "Sleep interval: $SLEEP_INTERVAL seconds"
        echo "Step-up: $STEP_UP%, Step-down: $STEP_DOWN%"
        ;;
    help) show_help ;;
    *) echo "Unknown command: $1"; show_help ;;
esac

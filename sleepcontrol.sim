SIM_FILE="/tmp/sleepcontrol.sim"
SIM_FILE_TMP="/tmp/sleepcontrol.sim.tmp"
#Atomically saving the timestamp array to prevent partial logs
save_sim_times() {
    local -n arr=$1  # pass array by name
    : > "$SIM_FILE_TMP"  # empty tmp file
    for ts in "${arr[@]}"; do
        echo "$ts" >> "$SIM_FILE_TMP"
    done
    mv "$SIM_FILE_TMP" "$SIM_FILE"
}
load_sim_times() {
    local -n arr=$1
    arr=()
    if [ -f "$SIM_FILE" ]; then
        mapfile -t arr < "$SIM_FILE"
    fi
}
